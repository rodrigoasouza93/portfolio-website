---
import Icon from "@/components/Icon.astro";
import { featuredProjects } from "@/data/projects";
---

<section id="projects" class="mx-auto max-w-6xl px-6 py-16 md:py-20">
  <div class="mb-10 grid gap-4 md:grid-cols-[minmax(0,0.9fr)_minmax(280px,0.55fr)] md:items-end">
    <div>
      <p class="mb-3 font-mono text-sm uppercase tracking-widest text-primary">Projeto em destaque</p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-5xl">Projetos em Destaque</h2>
    </div>
    <p class="leading-relaxed text-muted-foreground">
      O foco aqui é mostrar decisões técnicas, arquitetura e impacto de uso, não apenas uma galeria visual de telas.
    </p>
  </div>

  <div class="space-y-8">
    {
      featuredProjects.map((project) => (
        <div class="group relative rounded-lg border border-border bg-card p-6 transition-all duration-300 hover:border-primary/30 md:p-8">
          <div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div class="space-y-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="mb-3 font-mono text-xs uppercase tracking-widest text-muted-foreground">Mobile offline-first</p>
                  <h3 class="text-2xl font-bold text-card-foreground transition-colors group-hover:text-primary md:text-4xl">
                    {project.title}
                  </h3>
                </div>
                <a href={`/projects/${project.id}`} aria-label={`Ver detalhes de ${project.title}`} class="rounded-md bg-secondary p-2 text-muted-foreground transition-colors hover:bg-secondary/80 group-hover:text-primary">
                  <Icon name="arrow-up-right" size={20} />
                </a>
              </div>

              <p class="max-w-3xl leading-relaxed text-muted-foreground">{project.description}</p>

              <ul class="grid gap-3 sm:grid-cols-2">
                {project.highlights.map((highlight) => (
                  <li class="rounded-md border border-border bg-muted p-4 text-sm text-muted-foreground">
                    <strong class="mb-2 block text-foreground">{highlight.title}</strong>
                    {highlight.description}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-2 pt-4">
                {project.technologies.map((tech) => (
                  <span class="rounded-full border border-border bg-muted px-3 py-1 font-mono text-sm font-medium text-muted-foreground">{tech}</span>
                ))}
              </div>
            </div>

            <aside class="rounded-lg border border-border bg-secondary p-5">
              <dl class="space-y-4">
                <div class="flex justify-between gap-4 border-b border-border pb-4">
                  <dt class="text-sm text-muted-foreground">Papel</dt>
                  <dd class="text-right text-sm font-semibold">Arquiteto Mobile</dd>
                </div>
                <div class="flex justify-between gap-4 border-b border-border pb-4">
                  <dt class="text-sm text-muted-foreground">Stack</dt>
                  <dd class="text-right text-sm font-semibold">React Native, Expo, TS</dd>
                </div>
                <div class="flex justify-between gap-4 border-b border-border pb-4">
                  <dt class="text-sm text-muted-foreground">Foco</dt>
                  <dd class="text-right text-sm font-semibold">Offline-first e UX</dd>
                </div>
                <div class="flex justify-between gap-4">
                  <dt class="text-sm text-muted-foreground">Código</dt>
                  <dd class="text-right text-sm font-semibold">GitHub público</dd>
                </div>
              </dl>
            </aside>
          </div>
        </div>
      ))
    }
  </div>
</section>
