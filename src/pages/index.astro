---
import About from "@/components/About.astro";
import Contact from "@/components/Contact.astro";
import Credentials from "@/components/Credentials.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import SelectedWork from "@/components/SelectedWork.astro";
import Stack from "@/components/Stack.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const currentYear = new Date().getFullYear();
---

<BaseLayout>
  <main class="min-h-screen">
    <Header />
    <Hero />
    <Stack />
    <Credentials />
    <SelectedWork />
    <About />
    <Contact />
    <footer class="py-8 text-center text-sm text-muted-foreground">
      © {currentYear} Rodrigo Souza. All rights reserved.
    </footer>
  </main>
</BaseLayout>
